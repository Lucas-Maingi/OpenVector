// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums are not supported in SQLite, using strings instead
// Role: admin, analyst
// InvestigationStatus: active, archived, closed
// EvidenceType: url, text, image, document, note
// ConnectorType: username_search, domain_search, google_dork, reverse_image, breach_search, email_search

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  role              String   @default("analyst")
  stripeCustomerId  String?  @unique
  hasLifetimeAccess Boolean  @default(false)
  plan              String   @default("free") // free, pro, lifetime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  investigations Investigation[]
  searchLogs     SearchLog[]

  @@map("users")
}

model Investigation {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("active")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subject fields
  subjectName     String?
  subjectUsername String?
  subjectEmail    String?
  subjectPhone    String?
  subjectImageUrl String?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entities Entity[]
  evidence Evidence[]
  reports  Report[]
  logs     SearchLog[]

  @@index([userId])
  @@map("investigations")
}

model Entity {
  id              String   @id @default(uuid())
  investigationId String
  type            String // username, email, domain, phone, name, ip, url
  value           String
  notes           String?
  confidence      Int      @default(50) // 0-100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("entities")
}

model Evidence {
  id              String   @id @default(uuid())
  investigationId String
  type            String   @default("text")
  title           String
  content         String
  sourceUrl       String?
  tags            String   @default("")
  notes           String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("evidence")
}

model Report {
  id              String   @id @default(uuid())
  investigationId String
  title           String
  content         String
  format          String   @default("markdown")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("reports")
}

model SearchLog {
  id              String   @id @default(uuid())
  investigationId String?
  userId          String
  connectorType   String
  query           String
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  investigation Investigation? @relation(fields: [investigationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([investigationId])
  @@map("search_logs")
}
