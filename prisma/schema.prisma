// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums are not supported in SQLite, using strings instead
// Role: admin, analyst
// InvestigationStatus: active, archived, closed
// EvidenceType: url, text, image, document, note
// ConnectorType: username_search, domain_search, google_dork, reverse_image, breach_search, email_search

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  role              String   @default("analyst")
  stripeCustomerId  String?  @unique
  hasLifetimeAccess Boolean  @default(false)
  plan              String   @default("free") // free, pro, lifetime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  investigations Investigation[]
  searchLogs     SearchLog[]
  notifications  Notification[]
  feedback       Feedback[]
  watchlists     Watchlist[]

  @@map("users")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, success, warning, danger
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Investigation {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("active")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Subject fields
  subjectName     String?
  subjectUsername String?
  subjectEmail    String?
  subjectPhone    String?
  subjectDomain   String?
  subjectImageUrl String?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entities Entity[]
  evidence Evidence[]
  reports  Report[]
  logs     SearchLog[]

  @@index([userId])
  @@map("investigations")
}

model Entity {
  id              String   @id @default(uuid())
  investigationId String
  type            String // username, email, domain, phone, name, ip, url
  value           String
  notes           String?
  confidence      Int      @default(50) // 0-100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("entities")
}

model Evidence {
  id              String    @id @default(uuid())
  investigationId String
  type            String    @default("text")
  title           String
  content         String
  sourceUrl       String?
  tags            String    @default("")
  notes           String?
  isVerified      Boolean   @default(false)
  confidenceScore Float     @default(0.5) // 0.0 to 1.0 Signal-to-Noise Score
  confidenceLabel String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  eventDate       DateTime? // The chronological time the event occurred (for timelines)

  // Evidence Archiving & Provenance (Enterprise)
  sourceArchiveUrl   String? // URL to a permanent IPFS/S3 backup of the page
  screenshotUrl      String? // URL to a visual snapshot of the page/domain
  captureTimestamp   DateTime? // Exact time the snapshot was taken
  provenanceHash     String? // Cryptographic SHA-256 hash verifying evidence immutability
  provenanceSourceId String? // ID of the parent evidence that led to this discovery (Graph Link)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("evidence")
}

model Report {
  id              String   @id @default(uuid())
  investigationId String
  title           String
  content         String
  format          String   @default("markdown")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  investigation Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId])
  @@map("reports")
}

model SearchLog {
  id              String   @id @default(uuid())
  investigationId String?
  userId          String
  connectorType   String
  query           String
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  investigation Investigation? @relation(fields: [investigationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([investigationId])
  @@map("search_logs")
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  content   String
  type      String   @default("general") // bug, feature, general
  version   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("feedback")
}

model Watchlist {
  id          String   @id @default(uuid())
  userId      String
  name        String
  targetType  String   // email, username, domain, ip
  targetValue String
  status      String   @default("active") // active, paused
  lastChecked DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts WatchlistAlert[]

  @@index([userId])
  @@map("watchlists")
}

model WatchlistAlert {
  id          String   @id @default(uuid())
  watchlistId String
  title       String
  content     String
  severity    String   @default("info") // info, warning, critical
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@index([watchlistId])
  @@map("watchlist_alerts")
}
